{
  "name": "talk-library",
  "description": "Research presentation library for Slidev-based academic talks",
  "version": "1.0.0",
  "categories": {
    "themes": {
      "description": "Visual themes for research presentations",
      "path": "themes/",
      "items": [
        { "name": "academic-clean", "file": "academic-clean.json", "description": "White background, muted blue accents, serif headings" },
        { "name": "clinical-teal", "file": "clinical-teal.json", "description": "White background, teal/medical accents" }
      ]
    },
    "patterns": {
      "description": "Slide structure patterns for different talk modes",
      "path": "patterns/",
      "items": [
        { "name": "conference-standard", "file": "conference-standard.json", "mode": "CONFERENCE", "slides": 12 },
        { "name": "journal-club", "file": "journal-club.json", "mode": "JOURNAL_CLUB", "slides": 12 },
        { "name": "seminar-deep-dive", "file": "seminar-deep-dive.json", "mode": "SEMINAR", "slides": 35 },
        { "name": "defense-grant", "file": "defense-grant.json", "mode": "DEFENSE", "slides": 30 }
      ]
    },
    "animations": {
      "description": "Slide transition and element animations (reuse founder deck animations)",
      "path": null,
      "note": "Reference .claude/extensions/founder/context/project/founder/deck/animations/ directly"
    },
    "styles": {
      "description": "CSS styles for slide elements (reuse founder deck styles where applicable)",
      "path": null,
      "note": "Reference .claude/extensions/founder/context/project/founder/deck/styles/ for base styles"
    },
    "content": {
      "description": "Content templates for research presentation slides",
      "path": "contents/",
      "subcategories": {
        "title": ["title-standard.md", "title-institutional.md"],
        "motivation": ["motivation-gap.md", "motivation-clinical.md"],
        "methods": ["methods-study-design.md", "methods-flowchart.md", "methods-analysis.md"],
        "results": ["results-table.md", "results-figure.md", "results-forest-plot.md", "results-kaplan-meier.md"],
        "discussion": ["discussion-comparison.md"],
        "conclusions": ["conclusions-takeaway.md", "limitations-standard.md"],
        "acknowledgments": ["acknowledgments-funding.md", "questions-contact.md"]
      }
    },
    "components": {
      "description": "Vue components for research-specific slide elements",
      "path": "components/",
      "items": [
        { "name": "FigurePanel", "file": "FigurePanel.vue" },
        { "name": "DataTable", "file": "DataTable.vue" },
        { "name": "CitationBlock", "file": "CitationBlock.vue" },
        { "name": "StatResult", "file": "StatResult.vue" },
        { "name": "FlowDiagram", "file": "FlowDiagram.vue" }
      ]
    }
  }
}
