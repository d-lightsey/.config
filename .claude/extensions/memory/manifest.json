{
  "name": "memory",
  "version": "1.0.0",
  "description": "Obsidian-compatible memory vault for knowledge capture and retrieval with MCP integration",
  "language": null,
  "dependencies": [],
  "provides": {
    "commands": ["learn.md"],
    "skills": ["skill-memory"],
    "context": ["project/memory"],
    "data": [".memory"],
    "hooks": []
  },
  "merge_targets": {
    "claudemd": {
      "source": "EXTENSION.md",
      "target": ".claude/CLAUDE.md",
      "section_id": "extension_memory"
    },
    "index": {
      "source": "index-entries.json",
      "target": ".claude/context/index.json"
    }
  },
  "mcp_servers": {
    "obsidian-memory": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/obsidian-claude-code-mcp@latest"],
      "env": {
        "OBSIDIAN_WS_PORT": "22360"
      }
    }
  }
}
