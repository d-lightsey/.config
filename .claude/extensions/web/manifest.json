{
  "name": "web",
  "version": "1.0.0",
  "description": "Web development support with Astro, Tailwind CSS v4, TypeScript, and Cloudflare Pages",
  "language": "web",
  "dependencies": [],
  "provides": {
    "agents": ["web-implementation-agent.md", "web-research-agent.md"],
    "skills": ["skill-web-implementation", "skill-web-research", "skill-tag"],
    "commands": ["tag.md"],
    "rules": ["web-astro.md"],
    "context": ["project/web"],
    "scripts": [],
    "hooks": []
  },
  "merge_targets": {
    "claudemd": {
      "source": "EXTENSION.md",
      "target": ".claude/CLAUDE.md",
      "section_id": "extension_web"
    },
    "index": {
      "source": "index-entries.json",
      "target": ".claude/context/index.json"
    }
  },
  "mcp_servers": {}
}
